# ============================================
# New Balan Medical - Backend Environment Config
# ============================================
# Copy this file to .env and update the values
# cp .env.example .env

# Database Configuration
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
# Note: Special characters in password must be URL-encoded (e.g., @ = %40)
#
# Remote (e.g. Hostinger VPS):
# DATABASE_URL=postgresql+asyncpg://newbalanDev:NewBalan%402025@148.230.66.113:5432/newbalanDev
#
# Local:
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/new_balan
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Application Settings
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# CORS (comma-separated origins, or * for all)
# On VPS with SSL use your frontend origin, e.g. https://newbalanpharmacy.com
CORS_ORIGINS=*

# --------------------------------------------
# Storage (prescriptions and images)
# --------------------------------------------
# Backend: local (files on disk) or azure (Azure Blob Storage)
STORAGE_BACKEND=local

# Local storage path (used when STORAGE_BACKEND=local). Relative to backend root or absolute.
# On VPS (e.g. Hostinger) use a path that persists, e.g. /var/app/storage or ./storage
LOCAL_STORAGE_PATH=./storage

# Optional: Azure Blob Storage (only when STORAGE_BACKEND=azure)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER_NAME=prescriptions

# --------------------------------------------
# Razorpay Payment Gateway (get keys from https://dashboard.razorpay.com)
# --------------------------------------------
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
