# Database (required)
DATABASE_URL=postgresql+asyncpg://user:password@host:port/database

# Application
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

CORS_ORIGINS=*

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Local uploads: default is <parent-of-backend>/storage/devstorage (NOT inside new_balan_be)
STORAGE_BACKEND=local
# LOCAL_STORAGE_PATH=E:/FreeLance/vps-dev/storage/devstorage
