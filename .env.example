# Database — use ONE of the two modes:
#
# (A) Local / direct TCP (default): set DATABASE_URL (asyncpg). INSTANCE_CONNECTION_NAME must be unset.
DATABASE_URL=postgresql+asyncpg://user:password@host:port/database
#
# (B) Cloud Run + Cloud SQL: set INSTANCE_CONNECTION_NAME=project:region:instance and DB_USER, DB_PASSWORD, DB_NAME.
# Uses the Cloud SQL Python Connector with asyncpg. DATABASE_URL is not used by the app in this mode.
# INSTANCE_CONNECTION_NAME=
# DB_USER=
# DB_PASSWORD=
# DB_NAME=

# Application
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# JWT — optional; defaults are 30 min access, 7 days refresh (see app/config.py)
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7

# HTTP (defaults in app/config: HOST=0.0.0.0, PORT=8000). Run: uvicorn main:app --reload --host 0.0.0.0 --port 8000
# Frontend VITE_API_BASE_URL must be this origin (no trailing slash), e.g. http://127.0.0.1:8000

CORS_ORIGINS=*

# Razorpay — use test keys (rzp_test_*) from https://dashboard.razorpay.com/ ; never commit real secrets.
# Keys are read only by the backend; the SPA receives key_id from POST /razorpay/initiate after login.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Razorpay webhook secret (Dashboard -> Webhooks -> your endpoint -> Secret)
RAZORPAY_WEBHOOK_SECRET=
# Payment window before pending order auto-cancels (minutes)
PAYMENT_GRACE_MINUTES=30
# Payment grace window (minutes) before pending checkout is auto-cancelled.
PAYMENT_GRACE_MINUTES=10

# Storage: local | azure | gcs
STORAGE_BACKEND=local
# LOCAL_STORAGE_PATH=E:/FreeLance/vps-dev/storage/devstorage
# GCS (STORAGE_BACKEND=gcs): set bucket.
# Local dev: set GOOGLE_APPLICATION_CREDENTIALS to a service account JSON (relative to new_balan_be/ OK), or omit and use ADC (`gcloud auth application-default login`).
# Legacy: GCS_CREDENTIALS_PATH is accepted if GOOGLE_APPLICATION_CREDENTIALS is unset (same JSON file).
# If the key path is set but the file is missing, the app falls back to ADC instead of failing.
# Cloud Run: omit both — uses the runtime service account (ADC).
# GCS_BUCKET_NAME=your-bucket-name
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# GCS_CREDENTIALS_PATH=/secrets/gcs-key.json
