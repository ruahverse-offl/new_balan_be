# Version control
.git/
.gitignore
.dockerignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# Virtual environments (image installs deps from requirements.txt)
venv/
env/
ENV/
.venv/

# Secrets & local env (never bake into images)
.env
.env.*
!.env.example

# Tests & dev tooling (not needed to run the API)
test/
tests/
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Logs & local data
*.log
logs/
storage/

# Docs & misc (smaller build context)
*.md
LICENSE

# Large / credential JSON patterns (build context should not include keys)
*credentials*.json
*-firebase-adminsdk-*.json
*-service-account*.json
new-balan-*.json
